# Cara dapat MS_TOKEN:
# 1. Buka https://www.tiktok.com di Chrome dan login
# 2. Buka DevTools (F12) → Application → Cookies → https://www.tiktok.com
# 3. Cari cookie bernama "msToken", copy value-nya ke sini
# 4. Rename file ini jadi .env
#
# Tanpa MS_TOKEN, scraper kemungkinan langsung diblokir TikTok.
MS_TOKEN=

# (Opsional) Default: false (browser Chromium muncul terlihat — lebih friendly
# terhadap bot-detection TikTok). Set "true" buat sembunyikan window.
HEADLESS=false

# (Opsional) Delay antar user saat scrape (mode list_username) dalam detik.
# Default: 0 (no delay — paling cepat). Naikkan ke 2-5 kalau sering kena rate-limit.
SCRAPE_DELAY=0
